# Sector X Discord Bot Configuration

# Discord Bot
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_application_client_id_here
GUILD_ID=your_guild_id_here

# OpenAI (optional - for AI Chat)
OPENAI_API_KEY=your_openai_api_key_here
AI_CHANNEL_ID=channel_id_for_ai_chat

# Ticket System
TICKET_CATEGORY_ID=category_id_for_tickets
TICKET_CHANNEL_ID=channel_id_for_ticket_notifications
SUPPORT_ROLE_ID=role_id_that_can_manage_tickets

# Support Room (Voice)
WAITING_ROOM_NAME=Wartesaal
PRIVATE_CHANNEL_NAME=support

# Webhook (for web interface sync)
WEBHOOK_URL=webhook_url_for_ticket_updates

# Web Server
PORT=3001
